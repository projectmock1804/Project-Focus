# =============================================================================
# Project Focus - Environment Configuration
# Copy this file to .env and fill in your actual values
# =============================================================================

# ============================================================================
# Firebase Configuration (Required for Production)
# ============================================================================
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=project-focus-7722d

# Full service account JSON (for production/Render)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"project-focus-7722d",...}

# OR individual credentials (for development):
# FIREBASE_PRIVATE_KEY_ID=your_private_key_id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@project-id.iam.gserviceaccount.com

# ============================================================================
# Claude API Configuration (for task parsing and AI features)
# ============================================================================
ANTHROPIC_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-opus-4-1

# ============================================================================
# Server Configuration
# ============================================================================
PORT=3000
NODE_ENV=development

# ============================================================================
# Telegram Bot Configuration (Optional - currently disabled)
# ============================================================================
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================================================
# User Configuration
# ============================================================================
USER_TELEGRAM_ID=your_telegram_user_id_here
USER_NAME=박민철

# ============================================================================
# PC Agent Configuration (Optional)
# ============================================================================
AGENT_POLL_INTERVAL_MS=500
SERVER_BASE_URL=http://localhost:3000

# ============================================================================
# Frontend Configuration
# ============================================================================
VITE_API_URL=http://localhost:3000

# ============================================================================
# Admin Configuration
# ============================================================================
ADMIN_EMAILS=projectmock1804@gmail.com
