# =============================================================================
# Project Focus MVP - Environment Configuration
# Copy this file to .env and fill in your actual values
# =============================================================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic Claude API Key (from console.anthropic.com)
CLAUDE_API_KEY=your_claude_api_key_here

# Claude Model to use
CLAUDE_MODEL=claude-sonnet-4-5

# Google Sheets Configuration
GOOGLE_SHEETS_ID=your_google_sheet_id_here
# Path to your Google Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY=./google-service-account-key.json

# Server Configuration
PORT=3000
NODE_ENV=development

# User Configuration
USER_TELEGRAM_ID=your_telegram_user_id_here
USER_NAME=박민철

# PC Agent Configuration
AGENT_POLL_INTERVAL_MS=500
SERVER_BASE_URL=http://localhost:3000
