rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================================
    // Users Collection — users can only read/write their own documents
    // ============================================================================
    match /users/{userId} {
      // Allow users to read and write only their own document
      allow read: if request.auth.uid == userId;
      allow write: if request.auth.uid == userId;
    }

    // ============================================================================
    // Tasks Collection — users can only read/write their own tasks
    // ============================================================================
    match /tasks/{taskId} {
      // Allow users to read/write only their own tasks
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if request.auth.uid == resource.data.userId;
    }

    // ============================================================================
    // Sessions Collection — users can only read/write their own sessions
    // ============================================================================
    match /sessions/{sessionId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if request.auth.uid == resource.data.userId;
    }

    // ============================================================================
    // Task Requests Collection — users can only read/write their own requests
    // ============================================================================
    match /taskRequests/{requestId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if request.auth.uid == resource.data.userId;
    }

    // ============================================================================
    // Admin Stats Collection — deny all client access (admin only via backend)
    // ============================================================================
    match /adminStats/{document=**} {
      allow read, write: if false;  // Deny all - use backend API instead
    }

    // ============================================================================
    // Deny all other collections by default
    // ============================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
